{
  "name": "@proof/sqlite",
  "type": "module",
  "version": "0.1.0",
  "description": "Proof SDK SQLite-backed document storage adapters",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@proof/server": "0.1.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./store": {
      "types": "./dist/store.d.ts",
      "import": "./dist/store.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "clean": "rm -rf dist"
  }
}
